{
    "name": "杖剑传说小助手",
    "version":  "v0.1.0",
    "custom_title": "杖剑传说小助手",
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb"
        },
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "Visual Studio"
            }
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "{PROJECT_DIR}/resource"
            ]
        },
        {
            "name": "B 服",
            "path": [
                "{PROJECT_DIR}/resource"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "{PROJECT_DIR}/agent/main.py"
        ]
    },
    "task": [
        {
            "name": "启动杖剑传说官",
            "entry": "sub_启动杖剑传说官",
            "doc": "启动杖剑传说官服",
            "pipeline_override": {}
        },
        {
            "name": "打野猪",
            "entry": "FARM_点击世界",
            "pipeline_override": {
                "FARM_世界返回家园": {
                    "action": "StopTask"
                }
            }
        },
        {
            "name": "流水线",
            "entry": "FARM_点击杂货店"
        },
        {
            "name": "刷友情币",
            "entry": "开始刷友情点",
